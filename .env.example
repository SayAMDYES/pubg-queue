# Environment variables for PUBG Queue
PORT=8080
DB_PATH=./data/pubg_queue.db
ADMIN_USER=admin
# Generate with: htpasswd -bnBC 10 "" yourpassword | tr -d ':\n'
ADMIN_PASS_HASH=
SESSION_SECRET=change-this-to-a-random-32-byte-string
CSRF_SECRET=change-this-to-another-32byte-str!
TZ=Asia/Shanghai
ALLOW_DUPLICATE_NAME=false
RATE_LIMIT_REGISTER=5
RATE_LIMIT_LEAVE=5
SECURE_COOKIE=false
