# 趴布鸡排队 - 环境变量示例
# 复制此文件为 .env 并按需修改

# 服务端口
PORT=8080

# 数据库路径
DB_PATH=./data/pubg_queue.db

# 管理员密码（明文，通过 --admin-pass 命令行参数传入）
# Docker Compose 示例：command: ["./pubg-queue", "--admin-pass", "${ADMIN_PASS}"]
ADMIN_PASS=changeme

# Session 密钥（建议使用32字节随机字符串）
SESSION_SECRET=change-this-to-a-random-32-byte-string

# CSRF 密钥（建议使用32字节随机字符串）
CSRF_SECRET=change-this-to-another-32byte-str!

# 时区
TZ=Asia/Shanghai

# 是否允许同名报名（默认 false）
ALLOW_DUPLICATE_NAME=false

# 限流：报名每分钟最多 N 次（每IP）
RATE_LIMIT_REGISTER=5

# 限流：离队每分钟最多 N 次（每IP）
RATE_LIMIT_LEAVE=5

# 是否强制 HTTPS Cookie（生产环境设为 true）
SECURE_COOKIE=false

# PUBG API Key（可选，配置后启用战绩查询功能）
PUBG_API_KEY=

# PUBG 平台分区（默认 steam）
PUBG_SHARD=steam
